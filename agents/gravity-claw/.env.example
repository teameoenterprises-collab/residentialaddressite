# ------------------------------------------------------------------------------
# ⚠️ SECURE ENV VARS ONLY - DO NOT COMMIT THE ACTUAL .env FILE ⚠️
# ------------------------------------------------------------------------------

# Google Gemini (You have the 2TB Advanced plan, so API keys are generated in Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Telegram Bot (Free messaging, no webhooks required)
# 1. Message @BotFather on Telegram and send /newbot
# 2. Copy the token he gives you and paste it here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Security / Authorization (Crucial: Only respond to this exact Telegram User ID)
# Message @userinfobot on Telegram to get your numerical ID (e.g., 123456789)
AUTHORIZED_TELEGRAM_USER_ID=your_telegram_user_id
